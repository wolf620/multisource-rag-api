NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://rag:rag@postgres:5432/ragdb
REDIS_URL=redis://redis:6379
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
